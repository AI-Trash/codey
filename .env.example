# Flows
HEADLESS=false
SLOW_MO=0
OPENAI_BASE_URL=https://openai.com
CHATGPT_URL=https://chatgpt.com
DEFAULT_TIMEOUT_MS=15000
NAVIGATION_TIMEOUT_MS=30000

# PostgreSQL database
# DATABASE_URL=postgresql://codey:codey@localhost:5432/codey

# Exchange / Microsoft Graph (optional)
# EXCHANGE_TENANT_ID=your-tenant-id
# EXCHANGE_CLIENT_ID=your-app-client-id
# EXCHANGE_CLIENT_SECRET=your-app-client-secret
# EXCHANGE_MAILBOX=user@contoso.com
# EXCHANGE_CATCH_ALL_PREFIX=codey

# App backend / auth
# APP_URL=http://localhost:3000
# SESSION_SECRET=replace-this-with-a-long-random-string
# SESSION_COOKIE_NAME=codey_session
# GITHUB_CLIENT_ID=your-github-oauth-app-client-id
# GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret
# ADMIN_GITHUB_LOGINS=your-github-login
# VERIFICATION_API_KEY=shared-app-client-key
# VERIFICATION_API_KEY_HEADER=x-codey-api-key
# VERIFICATION_EMAIL_DOMAIN=example.com
# VERIFICATION_EMAIL_PREFIX=codey
# VERIFICATION_MAILBOX=codey-shared@example.com
# CLOUDFLARE_EMAIL_INGEST_SECRET=replace-this-with-a-long-random-string

# Virtual WebAuthn authenticator (optional)
# VIRTUAL_AUTHENTICATOR_AAGUID=d548826e-79b4-db40-a3d8-11116f7e8349

# App
# APP_BASE_URL=http://localhost:3000
# SESSION_COOKIE_NAME=codey_session
# SESSION_TTL_DAYS=14

# GitHub OAuth for browser admin login
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
# GITHUB_SCOPE=read:user user:email
# ADMIN_GITHUB_LOGINS=octocat,hubot
# FLOW_APP_API_KEY=replace-with-a-long-random-secret
# FLOW_APP_API_KEY_HEADER=x-codey-flow-app-key

# App-backed verification mailbox generation
# VERIFICATION_MAILBOX=codey@your-domain.com
# VERIFICATION_DOMAIN=your-domain.com
# VERIFICATION_RESERVATION_TTL_MINUTES=15

# Device authorization
# DEVICE_CHALLENGE_TTL_MINUTES=15

# Cloudflare Email Worker -> app webhook verification
# CLOUDFLARE_EMAIL_WEBHOOK_SECRET=replace-with-a-long-random-secret
# CLOUDFLARE_SIGNATURE_HEADER=x-codey-signature
# CLOUDFLARE_TIMESTAMP_HEADER=x-codey-timestamp

# Standards-based OAuth / OIDC backend foundation
# OAUTH_ISSUER=http://localhost:3000
# OAUTH_JWKS_JSON={"keys":[{"kty":"RSA","e":"AQAB","n":"...","d":"...","p":"...","q":"...","dp":"...","dq":"...","qi":"...","kid":"codey-dev","use":"sig","alg":"RS256"}]}
# OAUTH_CLIENT_SECRET_ENCRYPTION_KEY=base64-encoded-32-byte-key
# OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600
# OAUTH_DEVICE_CODE_TTL_SECONDS=600
# OAUTH_DEFAULT_RESOURCE_INDICATOR=http://localhost:3000
# OAUTH_SUPPORTED_SCOPES=flow-app-requests:write,notifications:read,verification:read,verification:reserve

# CLI app auth / notifications
# APP_BASE_URL=http://localhost:3000
# APP_CLI_EVENTS_PATH=/api/cli/events
# APP_DEVICE_START_PATH=/api/device
# APP_DEVICE_STATUS_PATH=/api/device/{deviceCode}
# APP_DEVICE_EVENTS_PATH=/api/device/{deviceCode}/events

# Codex OAuth + AxonHub channel creation (optional)
# CODEX_AUTHORIZE_URL=https://example.com/oauth/authorize
# CODEX_TOKEN_URL=https://example.com/oauth/token
# CODEX_CLIENT_ID=your-codex-client-id
# CODEX_CLIENT_SECRET=your-codex-client-secret
# CODEX_SCOPE=openid profile
# CODEX_REDIRECT_HOST=127.0.0.1
# CODEX_REDIRECT_PORT=3000
# CODEX_REDIRECT_PATH=/callback
# AXONHUB_BASE_URL=http://localhost:8080
# AXONHUB_ADMIN_EMAIL=admin@example.com
# AXONHUB_ADMIN_PASSWORD=replace-with-admin-password
# AXONHUB_PROJECT_ID=your-axonhub-project-guid
# AXONHUB_GRAPHQL_PATH=/admin/graphql
# CODEX_CHANNEL_NAME=Codex OAuth
# CODEX_CHANNEL_BASE_URL=https://api.openai.com
# CODEX_CHANNEL_TAGS=codex
# CODEX_CHANNEL_SUPPORTED_MODELS=codex-mini-latest
# CODEX_CHANNEL_MANUAL_MODELS=
# CODEX_CHANNEL_DEFAULT_TEST_MODEL=codex-mini-latest
