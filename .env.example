# Flows
HEADLESS=false
SLOW_MO=0
OPENAI_BASE_URL=https://openai.com
CHATGPT_URL=https://chatgpt.com
DEFAULT_TIMEOUT_MS=15000
NAVIGATION_TIMEOUT_MS=30000

# PostgreSQL database
# DATABASE_URL=postgresql://codey:codey@localhost:5432/codey

# Exchange / Microsoft Graph (optional)
# EXCHANGE_TENANT_ID=your-tenant-id
# EXCHANGE_CLIENT_ID=your-app-client-id
# EXCHANGE_CLIENT_SECRET=your-app-client-secret
# EXCHANGE_MAILBOX=user@contoso.com
# EXCHANGE_CATCH_ALL_PREFIX=codey

# App
# APP_BASE_URL=http://localhost:3000
# SESSION_COOKIE_NAME=codey_session
# SESSION_TTL_DAYS=14

# GitHub OAuth for browser admin login
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
# GITHUB_SCOPE=read:user user:email
# ADMIN_GITHUB_LOGINS=octocat,hubot
# FLOW_APP_API_KEY=replace-with-a-long-random-secret
# FLOW_APP_API_KEY_HEADER=x-codey-flow-app-key

# Verification API access
# VERIFICATION_API_KEY=shared-app-client-key
# VERIFICATION_API_KEY_HEADER=x-codey-api-key

# App-backed verification mailbox generation
# Verification domains are managed from /admin/domains and randomly selected
# from the enabled domain pool during CLI registration.
# VERIFICATION_EMAIL_PREFIX=codey
# VERIFICATION_RESERVATION_TTL_MINUTES=15
# Legacy single-domain bootstrap (optional compatibility seed only)
# VERIFICATION_MAILBOX=codey@your-domain.com
# VERIFICATION_DOMAIN=your-domain.com

# Device authorization
# DEVICE_CHALLENGE_TTL_MINUTES=15

# Cloudflare Email Worker -> app webhook verification
# CLOUDFLARE_EMAIL_WEBHOOK_SECRET=replace-with-a-long-random-secret
# CLOUDFLARE_SIGNATURE_HEADER=x-codey-signature
# CLOUDFLARE_TIMESTAMP_HEADER=x-codey-timestamp

# Standards-based OAuth / OIDC backend foundation
# OAUTH_ISSUER=http://localhost:3000
# OAUTH_JWKS_JSON={"keys":[{"kty":"RSA","e":"AQAB","n":"...","d":"...","p":"...","q":"...","dp":"...","dq":"...","qi":"...","kid":"codey-seed","use":"sig","alg":"RS256"}]}
# OAUTH_JWKS_JSON is optional and only used as a one-time seed if the signing-key table is empty.
# Also used to encrypt shared ChatGPT identity credentials stored by Codey app.
# OAUTH_CLIENT_SECRET_ENCRYPTION_KEY=base64-encoded-32-byte-key
# OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600
# OAUTH_DEVICE_CODE_TTL_SECONDS=600
# OAUTH_SIGNING_KEY_ROTATION_DAYS=30
# OAUTH_SIGNING_KEY_RETENTION_DAYS=7
# OAUTH_DEFAULT_RESOURCE_INDICATOR=http://localhost:3000
# OAUTH_SUPPORTED_SCOPES=flow-app-requests:write,notifications:read,verification:read,verification:reserve

# Shared Codey app client for flows and CLI auth
# If CODEY_APP_CLIENT_SECRET is set, verification flows use client_credentials.
# If it is omitted, verification flows fall back to device code authorization.
# CODEY_APP_BASE_URL=http://localhost:3000
# CODEY_APP_OIDC_ISSUER=http://localhost:3000/oidc
# CODEY_APP_OIDC_BASE_PATH=/oidc
# CODEY_APP_CLIENT_ID=your-codey-client-id
# CODEY_APP_CLIENT_SECRET=your-codey-client-secret
# CODEY_APP_RESOURCE=http://localhost:3000
# CODEY_APP_TOKEN_ENDPOINT_AUTH_METHOD=client_secret_basic
# CODEY_APP_CLI_EVENTS_PATH=/api/realtime/ws
# CODEY_APP_DEVICE_START_PATH=/api/device
# CODEY_APP_DEVICE_STATUS_PATH=/api/device/{deviceCode}
# CODEY_APP_DEVICE_EVENTS_PATH=/api/realtime/ws
# CODEY_APP_RESERVE_EMAIL_PATH=/api/verification/email-reservations
# CODEY_APP_CODE_PATH=/api/verification/codes
# CODEY_APP_EVENTS_PATH=/api/realtime/ws

# Codex OAuth (optional)
# Built-in defaults match OpenAI; uncomment only to override them.
# CODEX_AUTHORIZE_URL=https://auth.openai.com/oauth/authorize
# CODEX_TOKEN_URL=https://auth.openai.com/oauth/token
# CODEX_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann
# CODEX_CLIENT_SECRET=your-codex-client-secret
# CODEX_SCOPE=openid profile email offline_access
# CODEX_REDIRECT_HOST=localhost
# CODEX_REDIRECT_PORT=1455
# CODEX_REDIRECT_PATH=/auth/callback

# Sub2API sync for Codex OAuth sessions is configured in /admin/external-services.
# Codey Web keeps those credentials on the server and performs the Sub2API sync
# after the managed Codex session is saved.


