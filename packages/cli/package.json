{
  "name": "@codey/cli",
  "version": "1.0.0",
  "private": true,
  "description": "Runtime for validating OpenAI browser flows and Appium Android flows",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "module",
  "scripts": {
    "build": "esbuild src/cli.ts --bundle --platform=node --format=esm --target=node22 --sourcemap --outfile=dist/cli.js --packages=external --alias:@codey/state-machine=../state-machine/src/index.ts",
    "fmt": "oxfmt -c ../../.oxfmtrc.json",
    "fmt:check": "oxfmt -c ../../.oxfmtrc.json --check",
    "lint": "oxlint --config ../../.oxlintrc.json src vitest.config.ts test",
    "lint:fix": "oxlint --config ../../.oxlintrc.json src vitest.config.ts test --fix",
    "start": "node --enable-source-maps dist/cli.js",
    "test": "vitest run --config ./vitest.config.ts"
  },
  "dependencies": {
    "@codey/state-machine": "catalog:",
    "@faker-js/faker": "catalog:",
    "dotenv": "catalog:",
    "pino": "catalog:",
    "pino-pretty": "catalog:",
    "webdriverio": "catalog:",
    "xstate": "catalog:"
  },
  "devDependencies": {
    "@microsoft/microsoft-graph-client": "catalog:",
    "@types/node": "catalog:",
    "esbuild": "catalog:",
    "patchright": "catalog:"
  }
}
