{
    "name": "codey-cloudflare-email-worker",
    "main": "src/index.ts",
    "compatibility_date": "2026-04-14",
    "vars": {
        "CODEY_SIGNATURE_HEADER": "x-codey-signature",
        "CODEY_TIMESTAMP_HEADER": "x-codey-timestamp"
    },
    "observability": {
        "enabled": false,
        "head_sampling_rate": 1,
        "logs": {
            "enabled": true,
            "head_sampling_rate": 1,
            "persist": true,
            "invocation_logs": true
        },
        "traces": {
            "enabled": false,
            "persist": true,
            "head_sampling_rate": 1
        }
    }
}