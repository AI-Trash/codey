{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codey Desktop",
  "version": "0.1.0",
  "identifier": "com.codey.desktop",
  "build": {
    "beforeDevCommand": "pnpm run build:host && pnpm run dev:web",
    "beforeBuildCommand": "pnpm run build:host && pnpm run build:web",
    "devUrl": "http://127.0.0.1:11420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Codey Desktop",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../dist-host/automation-host.js": "automation-host/automation-host.js",
      "../dist-host/automation-host.js.map": "automation-host/automation-host.js.map"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [],
      "pubkey": ""
    }
  }
}
