    "pino-pretty": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "webdriverio": "catalog:",
    "xstate": "catalog:"
  },
  "devDependencies": {
    "@tauri-apps/cli": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "esbuild": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
