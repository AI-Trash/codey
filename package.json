{
  "name": "codey",
  "version": "1.0.0",
  "description": "Playwright library environment for validating OpenAI web flows with Chromium only",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "fmt": "pnpm --filter ./packages/flows run fmt",
    "fmt:check": "pnpm --filter ./packages/flows run fmt:check",
    "flow": "pnpm --filter ./packages/flows exec jiti",
    "lint": "pnpm --filter ./packages/flows run lint",
    "lint:fix": "pnpm --filter ./packages/flows run lint:fix",
    "test": "pnpm --filter ./packages/flows run test"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@tailwindcss/vite": "catalog:",
    "@tanstack/react-devtools": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-router-devtools": "catalog:",
    "@tanstack/react-router-ssr-query": "catalog:",
    "@tanstack/react-start": "catalog:",
    "@tanstack/router-plugin": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "dotenv": "^17.4.2",
    "lucide-react": "catalog:",
    "nitro": "3.0.260311-beta",
    "react": "catalog:",
    "react-dom": "catalog:",
    "server-only": "^0.0.1",
    "tailwind-merge": "catalog:",
    "tailwindcss": "catalog:",
    "tw-animate-css": "catalog:"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "catalog:",
    "@tailwindcss/typography": "catalog:",
    "@tanstack/devtools-vite": "catalog:",
    "@testing-library/dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "jsdom": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "prisma": "^7.7.0",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "better-sqlite3",
      "esbuild",
      "lightningcss",
      "prisma"
    ]
  }
}
